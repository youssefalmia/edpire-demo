# ── Edpire API ────────────────────────────────────────────────────────────────
# Your API key — generate it in Settings > Integrations > API Keys
EDPIRE_API_KEY=your_api_key_here

# Base URL of your Edpire instance (default: https://app.edpire.com)
EDPIRE_API_BASE_URL=https://app.edpire.com

# ── Redirect pattern ──────────────────────────────────────────────────────────
# Base URL for assessment take links — include your org subdomain
# Format: https://{your-org-slug}.edpire.com/take
NEXT_PUBLIC_EDPIRE_TAKE_BASE_URL=https://your-org.edpire.com/take

# ── This app ──────────────────────────────────────────────────────────────────
# Public URL of this demo app — used to construct return_url for redirect pattern
NEXT_PUBLIC_APP_URL=https://your-demo.vercel.app

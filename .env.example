# ── Edpire API ────────────────────────────────────────────────────────────────
# Your API key — generate it in your Edpire dashboard under Integrations > API Keys.
# Use a sandbox key (edp_test_...) while developing — it hits an isolated database.
EDPIRE_API_KEY=your_api_key_here
EDPIRE_API_BASE_URL=https://edpire.com

# Optional but recommended for the webhook-ready demo route.
# The /api/webhooks/edpire endpoint verifies X-Edpire-Signature with this secret.
EDPIRE_WEBHOOK_SECRET=your_webhook_secret_here

# ── Redirect pattern ──────────────────────────────────────────────────────────
# Optional direct take base. Keep this if you already know the exact take entrypoint.
NEXT_PUBLIC_EDPIRE_TAKE_BASE_URL=https://edpire.com/take

# Your assigned Edpire org slug (e.g. "maple-high").
# If your tenant has been provisioned, the demo will launch learners through:
#   https://{slug}.edpire.com/take/{shareCode}
# In practice, teams should contact Edpire admin/support to get their slug
# assigned and branded tenant provisioned.
NEXT_PUBLIC_EDPIRE_ORG_SLUG=your-org-slug

# Optional explicit tenant origin if you already know it.
# Example: https://your-org-slug.edpire.com
NEXT_PUBLIC_EDPIRE_TENANT_ORIGIN=

# ── This app ──────────────────────────────────────────────────────────────────
# URL of this app — used to build the return_url for the redirect pattern.
# http://localhost:3000 works fine for local development (it's a browser redirect, not a server callback).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Edpire API ────────────────────────────────────────────────────────────────
# Your API key — generate it in Settings > Integrations > API Keys
EDPIRE_API_KEY=your_api_key_here

# Base URL of your Edpire instance (default: https://app.edpire.com)
EDPIRE_API_BASE_URL=https://app.edpire.com

# ── Redirect pattern ──────────────────────────────────────────────────────────
# Base URL for assessment take links.
#   Production:  https://your-org.edpire.com/take  (subdomain must be provisioned by Edpire)
#   Local dev:   http://localhost:3001/take         (requires NEXT_PUBLIC_EDPIRE_ORG_SLUG below)
NEXT_PUBLIC_EDPIRE_TAKE_BASE_URL=http://localhost:3001/take

# Your org slug — only needed for local dev.
# On localhost, subdomain routing doesn't work so ?_subdomain= is appended automatically.
# In production, your subdomain is already part of NEXT_PUBLIC_EDPIRE_TAKE_BASE_URL.
NEXT_PUBLIC_EDPIRE_ORG_SLUG=your-org-slug

# ── This app ──────────────────────────────────────────────────────────────────
# Public URL of this app — used to construct return_url for redirect pattern.
# For local dev, use http://localhost:3000 (return_url is a browser redirect, not a server callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000

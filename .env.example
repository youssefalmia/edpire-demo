# ── Edpire API ────────────────────────────────────────────────────────────────
# Your API key — generate it in your Edpire dashboard under Integrations > API Keys.
# Use a sandbox key (edp_test_...) while developing — it hits an isolated database.
EDPIRE_API_KEY=your_api_key_here

# ── Redirect pattern ──────────────────────────────────────────────────────────
# The base URL for assessment take links — your org subdomain on edpire.com.
# Contact your Edpire account manager to get your subdomain provisioned.
NEXT_PUBLIC_EDPIRE_TAKE_BASE_URL=https://your-org.edpire.com/take

# ── This app ──────────────────────────────────────────────────────────────────
# URL of this app — used to build the return_url for the redirect pattern.
# http://localhost:3000 works fine for local development (it's a browser redirect, not a server callback).
NEXT_PUBLIC_APP_URL=http://localhost:3000
